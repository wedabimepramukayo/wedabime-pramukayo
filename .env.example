# ─── Database (Neon PostgreSQL) ──────────────────────────────────
# Neon works for both development and production (Cloudflare Pages compatible)
# Get your free Neon DB at https://neon.tech
DATABASE_URL="postgresql://neondb_owner:your-password@ep-cool-name-region.aws.neon.tech/neondb?sslmode=require"

# ─── Authentication ──────────────────────────────────────────────
AUTH_SECRET="your-secret-key-here-change-this"
NEXTAUTH_URL="http://localhost:3000"

# ─── Cloudinary (Image Storage) ──────────────────────────────────
# Sign up at https://cloudinary.com — free tier available
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_UPLOAD_FOLDER="wedabime-pramukayo"

# ─── Cloudflare Pages Deployment ─────────────────────────────────
# In Cloudflare Pages dashboard → Settings → Environment variables:
# 1. Set ALL the above variables
# 2. Set DATABASE_URL to your Neon PostgreSQL connection string
# 3. Set NEXTAUTH_URL to your Cloudflare Pages URL (e.g. https://wedabime-pramukayo.pages.dev)
# 4. Build command: bun run build
# 5. Build output directory: .open-next/assets
# 6. Node.js version: 22
#
# After first deploy, run `prisma db push` to create the database schema:
#   DATABASE_URL="your-neon-url" npx prisma db push
